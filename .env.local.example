# =============================================================
# .env.local.example — ตัวอย่าง Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# =============================================================

# --- Supabase (ได้จาก https://supabase.com → Project Settings → API) ---
# URL ของ Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Anon key — ใช้ฝั่ง client (ปลอดภัยเพราะมี RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Service role key — ใช้ฝั่ง server เท่านั้น ห้าม expose ไป client!
SUPABASE_SERVICE_KEY=your_service_role_key

# --- GitHub Actions (สำหรับ trigger scraper ด้วยตนเอง) ---
# Personal Access Token ของ GitHub (ต้องมีสิทธิ์ repo)
GITHUB_TOKEN=your_github_pat
# ชื่อ repo ในรูปแบบ owner/repo
GITHUB_REPO=username/villa-dashboard

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
